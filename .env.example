# Required: OpenAI API key for AI chat functionality (gpt-5-nano)
OPENAI_API_KEY=

# Optional: Massive (Polygon.io) API key for real market data.
# Leave empty to use the built-in GBM simulator (recommended for most users).
MASSIVE_API_KEY=

# Optional: Set to "true" for deterministic mock LLM responses (used in E2E tests).
LLM_MOCK=false
